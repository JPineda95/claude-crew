{
  "//": "Copy to .mcp.json and add ONLY the servers this project actually uses — every key here is live and Claude Code will try to launch it (the '//name' trick is NOT a comment). Ready-to-paste entries for playwright, supabase, github, sentry, notion, and semgrep are in docs/TOOLING.md's MCP menu. Never hardcode secrets here — reference environment variables (e.g. \"${VAR}\") and set them in your shell or .env, which is git-ignored.",

  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}

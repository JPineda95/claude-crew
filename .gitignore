# Built plugin output (generated by scripts/build-plugin.sh)
dist/

# PROJECT.md is tracked by default (it's the crew's single source of project
# truth — teams want it shared). Private, per-person notes go in
# PROJECT.local.md instead, which stays git-ignored.
PROJECT.local.md

# Per-project Claude Code local overrides & state
.claude/settings.local.json
.claude/agent-memory-local/
.agent-locks/
.worktrees/

# Env & secrets — never commit
.env
.env.*
!.env.example
*.pem
id_rsa*
secrets/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Dependencies / build artifacts (uncomment per project as needed)
# node_modules/
__pycache__/
*.pyc
# target/
# bin/
# obj/

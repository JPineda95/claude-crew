# claude-crew project knobs — committed with the repo (template: templates/crew.env).
#
# ':=' means: if a value is already exported in the calling shell/session
# environment, that value wins and this default is never applied.
#
# This repo's own validation gate (CONTRIBUTING.md): script syntax checks,
# shellcheck, and the plugin build with its version-consistency assertions.

: "${CLAUDE_VALIDATE_CMD:=bash scripts/check.sh}"
: "${CLAUDE_E2E_SMOKE_CMD:=}"       # no e2e layer — this repo ships prompts + shell, not an app
: "${CLAUDE_INTEGRATION_BRANCH:=dev}"
: "${BLOCK_ON_FAILURE:=}"

export CLAUDE_VALIDATE_CMD CLAUDE_E2E_SMOKE_CMD CLAUDE_INTEGRATION_BRANCH BLOCK_ON_FAILURE
